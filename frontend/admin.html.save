const API_BASE = "https://job-scout-pro-backend.onrender.com/api";<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Admin Dashboard - Job Scout Pro</title>
<link rel="stylesheet" href="style.css" />
<style>
.admin-page {
padding: 30px 20px 60px;
max-width: 1200px;
margin: 0 auto;
}

.admin-header {
margin-bottom: 30px;
}

.admin-header h1 {
font-size: 36px;
color: #111827;
margin-bottom: 8px;
}

.admin-header p {
color: #6b7280;
}

.stats-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
gap: 20px;
margin-bottom: 30px;
}

.stat-box {
background: #ffffff;
padding: 22px;
border-radius: 16px;
box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
}

.stat-box h3 {
font-size: 30px;
color: #2563eb;
margin-bottom: 6px;
}

.admin-section {
background: #ffffff;
padding: 24px;
border-radius: 16px;
box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
margin-bottom: 24px;
}

.admin-section h2 {
margin-bottom: 18px;
color: #111827;
}

.admin-table {
width: 100%;
border-collapse: collapse;
overflow-x: auto;
}

.admin-table th,
.admin-table td {
text-align: left;
padding: 12px;
border-bottom: 1px solid #e5e7eb;
font-size: 14px;
}

.admin-table th {
background: #f9fafb;
color: #374151;
}

.empty-row {
color: #6b7280;
padding: 16px 0;
}

.quick-actions {
display: flex;
gap: 14px;
flex-wrap: wrap;
}
</style>
</head>
<body>
<header class="topbar">
<div class="logo-area">
<img src="assets/logo.Jobscoutphoto.jpg" alt="Job Scout Pro Logo" class="logo" />
<div>
<h1>Job Scout Pro</h1>
<p class="tagline">
Admin Control Panel
</p>
</div>
</div>

<nav class="nav-links">
<a href="index.html">Home</a>
<a href="jobs.html">Jobs</a>
<a href="payment.html">Payments</a>
<a href="contact.html">Contact</a>
</nav>
</header>

<main class="admin-page">
<div class="admin-header">
<h1>Admin Dashboard</h1>
<p>
Monitor jobs, users, featured listings, and payment activity.
</p>
</div>

<div class="stats-grid">
<div class="stat-box">
<h3 id="totalJobs">0</h3>
<p>
Total Jobs
</p>
</div>
<div class="stat-box">
<h3 id="totalUsers">0</h3>
<p>
Total Users
</p>
</div>
<div class="stat-box">
<h3 id="featuredJobs">0</h3>
<p>
Featured Jobs
</p>
</div>
<div class="stat-box">
<h3 id="pendingPayments">0</h3>
<p>
Pending Payments
</p>
</div>
</div>

<section class="admin-section">
<h2>Quick Actions</h2>
<div class="quick-actions">
<a href="jobs.html" class="btn btn-primary">View Jobs</a>
<a href="payment.html" class="btn btn-secondary">Check Payments</a>
<a href="signup.html" class="btn btn-outline">Create User</a>
</div>
</section>

<section class="admin-section">
<h2>Recent Jobs</h2>
<div style="overflow-x:auto;">
<table class="admin-table">
<thead>
<tr>
<th>Title</th>
<th>Company</th>
<th>Location</th>
<th>Category</th>
<th>Featured</th>
</tr>
</thead>
<tbody id="recentJobsTable">
<tr>
<td colspan="5" class="empty-row">Loading jobs...</td>
</tr>
</tbody>
</table>
</div>
</section>
</main>

<script>
const API_BASE = "https://job-scout-pro-backend.onrender.com/api";

const totalJobs = document.getElementById("totalJobs");
const totalUsers = document.getElementById("totalUsers");
const featuredJobs = document.getElementById("featuredJobs");
const pendingPayments = document.getElementById("pendingPayments");
const recentJobsTable = document.getElementById("recentJobsTable");

async function loadStats() {
try {
const response = await fetch(`${API_BASE}/admin/stats`);
const data = await response.json();

if (data.success) {
totalJobs.textContent = data.totalJobs ?? 0;
totalUsers.textContent = data.totalUsers ?? 0;
featuredJobs.textContent = data.featuredJobs ?? 0;
pendingPayments.textContent = data.pendingPayments ?? 0;
}
} catch (error) {
console.error("Failed to load admin stats:", error);
}
}

async function loadRecentJobs() {
try {
const response = await fetch(`${API_BASE}/jobs`);
const jobs = await response.json();

if (!Array.isArray(jobs) || jobs.length === 0) {
recentJobsTable.innerHTML = `
<tr>nano ~/job-scout-pro/frontend/admin.html

<td colspan="5" class="empty-row">No jobs found.</td>
</tr>
`;
return;
}

recentJobsTable.innerHTML = jobs.slice(0, 8).map(job => `
<tr>
<td>${job.title || "Untitled"}</td>
<td>${job.company || "N/A"}</td>
<td>${job.location || "N/A"}</td>
<td>${job.category || "General"}</td>
<td>${Number(job.is_featured) === 1 ? "Yes": "No"}</td>
</tr>
`).join("");
} catch (error) {
recentJobsTable.innerHTML = `
<tr>
<td colspan="5" class="empty-row">Failed to load jobs.</td>
</tr>
`;
}
}

document.addEventListener("DOMContentLoaded", () => {
loadStats();
loadRecentJobs();
});
</script>
</body>
</html>
grep -n 'API_BASE\|fetch\|payment\|submit\|form\|button' ~/job-scout-pro/frontend/payment.html



